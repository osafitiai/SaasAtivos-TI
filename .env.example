# Banco de dados PostgreSQL (Docker Compose expõe a porta 5433 no host)
DATABASE_URL="postgres://osafi:osafi_dev_password@localhost:5433/osafi_ativos"

# Segredo para assinar tokens de sessão (JWT). Troque em produção por um valor aleatório longo.
AUTH_SECRET="troque-este-segredo-por-um-valor-aleatorio-bem-longo-em-producao"

# Duração da sessão em segundos (padrão 8 horas)
SESSION_MAX_AGE=28800

# Supabase Storage — armazenamento de anexos/documentos (obrigatório em produção/Vercel)
# SUPABASE_URL="https://SEU-PROJETO.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="sua-chave-secreta-service-role"
# SUPABASE_BUCKET="documents"

# Fuso horário e localidade da aplicação
TZ="America/Sao_Paulo"

# Senha do usuário administrador criada pelo seed (opcional; padrão: osafi123)
# SEED_ADMIN_PASSWORD="defina-uma-senha-forte"

# Segredo para autorizar o job de alertas via agendador externo (opcional)
# CRON_SECRET="um-token-aleatorio-para-o-cron"
